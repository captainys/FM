ALL : BUILD\PLCHLDR EXE\PLCHLDR EXE\TESTSEND.EXP EXE\XMRECV.EXP EXE\XMSEND.EXP



BUILD\PLCHLDR :
	MKDIR BUILD
	ECHO PLACEHOLDER > BUILD\PLCHLDR

EXE\PLCHLDR :
	MD EXE
	ECHO PLACEHOLDER > EXE\PLCHLDR


BUILD\RS232C32.OBJ : RS232C32.ASM
	386asm RS232C32.ASM -OBJECT BUILD\RS232C32.OBJ


BUILD\DEBUG.OBJ : DEBUG.C
	run386 -nocrt D:\HC386\BIN\HCD386P DEBUG.C -OBJ BUILD\DEBUG.OBJ


BUILD\TESTSEND.OBJ : TESTSEND.C
	run386 -nocrt D:\HC386\BIN\HCD386P TESTSEND.C -OBJ BUILD\TESTSEND.OBJ

EXE\TESTSEND.EXP : BUILD\TESTSEND.OBJ BUILD\RS232C32.OBJ
	386LINK BUILD\TESTSEND.OBJ BUILD\RS232C32.OBJ @LIBS.LN -EXE EXE\TESTSEND.EXP



BUILD\XMRECV.OBJ : XMRECV.C
	run386 -nocrt D:\HC386\BIN\HCD386P XMRECV.C -OBJ BUILD\XMRECV.OBJ

EXE\XMRECV.EXP : BUILD\XMRECV.OBJ BUILD\RS232C32.OBJ BUILD\DEBUG.OBJ
	386LINK BUILD\XMRECV.OBJ BUILD\RS232C32.OBJ BUILD\DEBUG.OBJ @LIBS.LN -EXE EXE\XMRECV.EXP -MAP BUILD\XMRECV.MAP



BUILD\XMSEND.OBJ : XMSEND.C
	run386 -nocrt D:\HC386\BIN\HCD386P XMSEND.C -OBJ BUILD\XMSEND.OBJ

EXE\XMSEND.EXP : BUILD\XMSEND.OBJ BUILD\RS232C32.OBJ BUILD\DEBUG.OBJ
	386LINK BUILD\XMSEND.OBJ BUILD\RS232C32.OBJ BUILD\DEBUG.OBJ @LIBS.LN -EXE EXE\XMSEND.EXP -MAP BUILD\XMSEND.MAP
